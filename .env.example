# Приклад налаштувань (скопіюйте цей файл і назвіть його .env)

# Для локальної розробки використовуємо базу даних з Docker
DATABASE_URL=postgres://postgres:postgres_password@db:5432/erp_db

# Секретний ключ для локальної розробки (не використовувати в продакшені!)
SECRET_KEY=your-super-secret-local-key-123